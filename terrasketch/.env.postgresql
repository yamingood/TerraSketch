# Configuration PostgreSQL pour TerraSketch
DEBUG=True
SECRET_KEY=votre-cle-secrete-ici

# Base de données PostgreSQL
DB_NAME=terrasketch_db
DB_USER=terrasketch_user  
DB_PASSWORD=terrasketch_pass
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Sécurité (pour la production)
SECURE_SSL_REDIRECT=False

# APIs externes
ANTHROPIC_API_KEY=votre-cle-anthropic
STRIPE_PUBLISHABLE_KEY=votre-cle-stripe-public
STRIPE_SECRET_KEY=votre-cle-stripe-secrete

# Fichiers et médias
MEDIA_URL=/media/
STATIC_URL=/static/